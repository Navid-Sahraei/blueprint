# Supabase — create a project at https://supabase.com, then copy these from
# Project Settings → API. The app runs without them (auth is disabled and
# /app routes stay open) so the marketing site can be developed independently.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe — required only when subscription gating is wired up (roadmap).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
